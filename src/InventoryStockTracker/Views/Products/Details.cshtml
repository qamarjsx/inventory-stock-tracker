@using InventoryStockTracker.Entities
@model InventoryStockTracker.ViewModels.ProductDetailViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="page-header">
    <div>
        <h1 class="page-title">@Model.Name</h1>
        <p class="page-subtitle">
            @Model.Sku
            @if (!Model.IsActive)
            {
                <span class="badge-app badge-muted">Inactive</span>
            }
        </p>
    </div>
    <div style="display:flex; gap: var(--space-3);">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-app btn-app-secondary">Edit Product</a>
        @if (Model.IsActive)
        {
            <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Deactivate this product? It will be hidden from active use but its history is kept.');">
                <button type="submit" class="btn-app btn-app-secondary">Deactivate</button>
            </form>
        }
        else
        {
            <form asp-action="Reactivate" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn-app btn-app-primary">Reactivate</button>
            </form>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert-app alert-app-success">@successMessage</div>
}

<div class="detail-grid">
    <section class="detail-card">
        <h2 class="detail-card-title">Overview</h2>
        <dl class="detail-list">
            <dt>Current Stock</dt>
            <dd>
                @Model.CurrentStock
                @if (Model.IsLowStock)
                {
                    <span class="badge-app badge-danger">Low stock</span>
                }
            </dd>
            <dt>Reorder Level</dt>
            <dd>@Model.ReorderLevel</dd>
            <dt>Description</dt>
            <dd class="cell-secondary">@(Model.Description ?? "—")</dd>
        </dl>
    </section>

    <section class="detail-card">
        <h2 class="detail-card-title">Record Movement</h2>
        <form asp-action="RecordMovement" asp-route-id="@Model.Id" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="MovementForm.Type" class="form-label"></label>
                <select asp-for="MovementForm.Type" asp-items="Html.GetEnumSelectList<StockMovementType>()"
                        class="form-select"></select>
                <span asp-validation-for="MovementForm.Type" class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="MovementForm.Quantity" class="form-label"></label>
                <input asp-for="MovementForm.Quantity" class="form-input" />
                <span asp-validation-for="MovementForm.Quantity" class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="MovementForm.Note" class="form-label"></label>
                <input asp-for="MovementForm.Note" class="form-input" />
                <span asp-validation-for="MovementForm.Note" class="field-validation"></span>
            </div>

            <button type="submit" class="btn-app btn-app-primary">Record Movement</button>
        </form>
    </section>
</div>

<section class="detail-card">
    <h2 class="detail-card-title">Movement History</h2>
    @if (!Model.Movements.Any())
    {
        <div class="empty-state">
            <div class="empty-state-title">No movements yet</div>
            <p>Record the first movement above.</p>
        </div>
    }
    else
    {
        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Quantity</th>
                        <th>Note</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var movement in Model.Movements)
                    {
                        <tr>
                            <td class="cell-secondary">@movement.CreatedUtc.ToString("g")</td>
                            <td>
                                @if (movement.Type == StockMovementType.In)
                                {
                                    <span class="badge-app badge-success">In</span>
                                }
                                else
                                {
                                    <span class="badge-app badge-danger">Out</span>
                                }
                            </td>
                            <td>@movement.Quantity</td>
                            <td class="cell-secondary">@(movement.Note ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}